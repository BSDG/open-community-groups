# Example .env file for OCG Docker Compose deployment
# Copy this to .env and fill in your actual values

# ===== DATABASE (External PostgreSQL Cluster) =====
# Your existing PostgreSQL cluster connection details
DB_HOST=postgres.example.com
DB_PORT=5432
DB_NAME=ocg
DB_USER=ocg
DB_PASSWORD=your_secure_db_password_here

# ===== SERVER =====
# Your public domain (REQUIRED - this is what users see in their browser)
SERVER_BASE_URL=https://ocg.example.com

# Cookie security (true for HTTPS/production, false for local testing only)
COOKIE_SECURE=true

# ===== EMAIL (BREVO) =====
# From address (should be a domain you control or Brevo verified domain)
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Display name in "From:" field
EMAIL_FROM_NAME=Open Community Groups

# Brevo SMTP settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-email@example.com
SMTP_PASSWORD=your-brevo-smtp-key

# Optional: whitelist specific email addresses for testing/staging
# Leave empty or comment out to allow all. Format: email1@example.com,email2@example.com
# EMAIL_WHITELIST=test@example.com,admin@example.com

# ===== GITHUB OAUTH (OPTIONAL) =====
# Only fill these in if you want to enable GitHub login
# Get these from: GitHub Org Settings > Developer settings > OAuth Apps

# Set to "true" to enable GitHub login
GITHUB_OAUTH_ENABLED=false

# Your GitHub OAuth app credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===== IMAGE STORAGE =====
# "db" = store images in PostgreSQL (simplest, default)
# "s3" = store images in S3-compatible storage (requires additional config)
IMAGE_PROVIDER=db

# ===== LOGGING =====
# "json" = JSON structured logs (recommended for production)
# "pretty" = human-readable logs (good for local development)
LOG_FORMAT=json
